d4wee.codeforpakistan.org {
    reverse_proxy localhost:8000
    
    # Enable compression
    encode gzip
    
    # Logs
    log {
        output file /var/log/caddy/d4wee.log
        format json
    }
    
    # Handle static files efficiently
    handle /static/* {
        root * /root/d4wee
        file_server
    }
}
